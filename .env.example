# Public canonical URL used by Nuxt SEO/sitemap metadata.
BASE_URL=https://your-domain.com

# Nuxt Studio GitHub OAuth credentials.
# Create a GitHub OAuth App with callback:
# https://your-domain.com/__nuxt_studio/auth/github
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# Optional repository overrides for Nuxt Studio.
STUDIO_REPOSITORY_OWNER=doguskysilva
STUDIO_REPOSITORY_NAME=doguskysilva
STUDIO_BRANCH_NAME=main

# Optional: restrict who can access Studio (comma-separated emails).
# STUDIO_GITHUB_MODERATORS=
